class Solution {
    public int maxSubarraySum(int[] arr, int k) {
        // Code here
        int low=0;
        int sum=0;
        for(int i=0;i<k;i++)
        {
            sum+=arr[i];
        }
        int res=sum;
        for (int i=k;i<arr.length;i++)
        {
            sum=sum-arr[i-k]+arr[i];
            res=Math.max(res,sum);
        }
        return res;
        
    }
}
