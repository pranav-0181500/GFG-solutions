class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int largest=-1;
        for (int i=0;i<arr.length;i++)
        {
            if (arr[i]>largest)
              largest=arr[i];
        }
        int seclargest=-1;
        for (int i=0;i<arr.length;i++)
        {if (arr[i]>seclargest && arr[i]!=largest)
             seclargest=arr[i];
        }
        return seclargest;
    }
}
