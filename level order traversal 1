class Solution {
    public ArrayList<Integer> levelOrder(Node root) {
        // code here
        Queue<Node> q=new LinkedList<>();
        q.add(root);
        Node temp;
        ArrayList<Integer> ans=new ArrayList<>();
        while(!q.isEmpty())
        {
            temp=q.peek();
            q.remove();
            ans.add(temp.data);
            if(temp.left!=null)
            {
                q.add(temp.left);
            }
            if(temp.right!=null)
            {
                q.add(temp.right);
            }
        }
        return ans;
    }
}
