class Solution {
    public Node insertAtEnd(Node head, int x) {
        // code here
        Node temp1=new Node(x);
        if (head==null)
        return temp1;
        Node temp=head;
        while (temp.next!=null)
        {
            temp=temp.next;
        }
        temp.next=temp1;
        return head;
    }
}
