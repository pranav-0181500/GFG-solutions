class Solution {
    static void dfs(Node root,ArrayList<Integer> ans)
{
    if (root==null)
    return ;
    dfs(root.left,ans);
    ans.add(root.data);
    dfs(root.right,ans);
}
    public ArrayList<Integer> inOrder(Node root) {
        // code here
        ArrayList<Integer> ans=new ArrayList<>();
        dfs(root,ans);
        return ans;
    }
}
