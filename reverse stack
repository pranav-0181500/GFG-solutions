class Solution {
    public static void reverseStack(Stack<Integer> st) {
        ArrayList<Integer> ans=new ArrayList<>();
        while(st.size()>0)
        {
            ans.add(st.pop());
        }
        for(int i=0;i<ans.size();i++)
        {
            st.push(ans.get(i));
        }
        
    }
}
