class Solution {
    void pushZerosToEnd(int[] arr) {
        // code here
     int i=0;
     int j=0;
     while(i<arr.length && j<arr.length)
     {
         if(arr[i]!=0)
         {
             int temp=arr[i];
             arr[i]=arr[j];
             arr[j]=temp;
             i++;
             j++;
         }
         else 
    {
           int temp=arr[i];
             arr[i]=arr[j];
             arr[j]=temp;
             i++;
             
    }
     }
    }
}
