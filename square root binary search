class Solution {
    int floorSqrt(int n) {
        // code here
        int s=0;
        int e=n;
        int ans=0;
        while(s<=e)
        {
            int mid=s+(e-s)/2;
            int val=mid*mid;
            if(val==n)
            return mid;
            else if(val<n)
            {
           ans=mid;
            s=mid+1;
            }
            else
            e=mid-1;
        }
        return ans;
    }
}
