class Solution {
    public int binarysearch(int[] arr, int k) {
        // Code Here
        int index=-1;
        int s=0;
        int e=arr.length-1;
        
          while (s<=e)
          {
        int mid=s+(e-s)/2;
        if (arr[mid]==k)
        {
            index=mid;
            e=mid-1;
        }
        else if(arr[mid]>k)
        {
            e=mid-1;
        }
        else
        s=mid+1;
          }
        
        return index;
    }
}
