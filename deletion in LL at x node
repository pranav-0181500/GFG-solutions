class Solution {
    Node deleteNode(Node head, int x) {
        // code here
        if( head.next==null) return null;
        if(x==1) return head.next;
        Node temp=head;
        //
        temp=head;
        for(long i=1;i<x-1;i++)
        {
            temp=temp.next;
            
        }
        temp.next=temp.next.next;
        return head;
    }
}
