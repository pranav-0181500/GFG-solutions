class Solution {
    public static int intersectSize(int a[], int b[]) {
        // Your code here
        int n1=a.length;
        int n2=b.length;
        HashSet<Integer> set=new HashSet<>();
        for(int ele:a)
        {
              set.add(ele);
        }
        for(int ele:b)
        {
            set.add(ele);
        }
        int n=set.size();
        return (n1+n2)-n;
    }
}
