class Solution {
    public int findFloor(int[] arr, int x) {
        int i=0;
        int n=arr.length-1;
        int ans=-1;
        while(i<=n)
        {
            int mid=i+(n-i)/2;
            if(arr[mid]<=x)
            {
                ans=mid;
                i=mid+1;
            }
            else if(arr[mid]>x)
            {
                n=mid-1;
            }
        }
       return ans; 
    }
}
