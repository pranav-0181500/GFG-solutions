class Solution {
    public int lengthOfLoop(Node head) {
        // code here
        Node slow=head;
        Node fast=head;
        if(head==null) return 0;
        while(fast!=null && fast.next!=null)
        {
            slow=slow.next;
            fast=fast.next.next;
            if(slow==fast)
              break;
        }
        if(fast==null || fast.next==null) return 0;
        int count=1;
        slow=fast.next;
        while(slow!=fast)
        {
            count++;
            slow=slow.next;
        }
        return count;
    }
}
