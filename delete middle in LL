class Solution {
    public Node deleteMid(Node head) {
        // code here
        Node temp=head;
        int count=0;
        while(temp!=null)
        {
            count++;
            temp=temp.next;
        }
        if(count==1)
        return null;
        temp=head;
        for(int i=1;i<(count/2);i++)
        {
            temp=temp.next;
        }
        temp.next=temp.next.next;
        return head;
    }
}
