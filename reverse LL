class Solution {
    Node reverseList(Node head) {
        // code here
        Node temp=head;
        Stack<Integer> st=new Stack<>();
        while(temp!=null)
        {
            st.add(temp.data);
            temp=temp.next;
        }
        temp=head;
        while(temp!=null)
        {
            temp.data=st.peek();
            st.pop();
            temp=temp.next;
        }
        return head;
      
    }
}
