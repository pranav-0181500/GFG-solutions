class Solution {
    public Node insertInMiddle(Node head, int x) {
        // code here
        if(head==null) return new Node(x);
        Node temp=head;
        Node temp1=head;
        while(temp1.next!=null && temp1.next.next!=null)
        {
            temp=temp.next;
            temp1=temp1.next.next;
        }
       Node node=new Node(x);
       node.next=temp.next;
       temp.next=node;
       return head;
    
    }
}
